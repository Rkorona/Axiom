{
  "name": "Java",
  "scopeName": "source.java",
  "fileTypes": ["java"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.java", "match": "//.*$" },
        {
          "name": "comment.block.documentation.java",
          "begin": "/\\*\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.java" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.java" } }
        },
        {
          "name": "comment.block.java",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.java" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.java" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.java",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.java", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.java",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.java", "match": "\\\\." }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.type.annotation.java",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.java",
          "match": "\\b(if|else|for|while|do|return|break|continue|switch|case|default|try|catch|finally|throw|throws|instanceof|new)\\b"
        },
        {
          "name": "storage.type.java",
          "match": "\\b(class|interface|enum|record|package|import|extends|implements|void|int|long|double|float|boolean|char|byte|short)\\b"
        },
        {
          "name": "storage.modifier.java",
          "match": "\\b(public|private|protected|static|final|abstract|synchronized|native|volatile|transient|strictfp|sealed|permits|var)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.java",
          "match": "\\b(true|false|null|this|super)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.java",
          "match": "\\b(0x[0-9a-fA-F_]+[lL]?|0b[01_]+[lL]?|[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9]+)?[fFdDlL]?)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.java",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.java",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        }
      ]
    }
  }
}
