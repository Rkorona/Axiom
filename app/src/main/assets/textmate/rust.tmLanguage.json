{
  "name": "Rust",
  "scopeName": "source.rust",
  "fileTypes": ["rs"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#attributes" },
    { "include": "#macros" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#lifetimes" },
    { "include": "#types" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.rust", "match": "//.*$" },
        {
          "name": "comment.block.rust",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.rust" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.rust" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.rust",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.rust", "match": "\\\\." }]
        },
        {
          "name": "string.quoted.single.rust",
          "match": "'(?:\\\\.|[^'])'"
        },
        {
          "name": "string.quoted.raw.rust",
          "begin": "r#*\"",
          "end": "\"#*"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "storage.type.annotation.rust",
          "begin": "#!?\\[",
          "end": "\\]",
          "beginCaptures": { "0": { "name": "punctuation.definition.annotation.rust" } },
          "endCaptures": { "0": { "name": "punctuation.definition.annotation.rust" } }
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "entity.name.function.macro.rust",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)!"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.rust",
          "match": "\\b(if|else|match|for|while|loop|break|continue|return|yield|await|async|in|as|where)\\b"
        },
        {
          "name": "storage.type.rust",
          "match": "\\b(fn|let|const|static|struct|enum|trait|impl|type|union|mod|use|pub|crate|super|self|extern)\\b"
        },
        {
          "name": "storage.modifier.rust",
          "match": "\\b(mut|ref|move|dyn|unsafe|abstract|virtual|override|final|box)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.rust",
          "match": "\\b(true|false|self|Self|super)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.rust",
          "match": "\\b(0x[0-9a-fA-F_]+(?:u8|u16|u32|u64|u128|usize|i8|i16|i32|i64|i128|isize)?|0o[0-7_]+|0b[01_]+|[0-9][0-9_]*(?:\\.[0-9][0-9_]*)?(?:[eE][+-]?[0-9]+)?(?:f32|f64|u8|u16|u32|u64|u128|usize|i8|i16|i32|i64|i128|isize)?)\\b"
        }
      ]
    },
    "lifetimes": {
      "patterns": [
        {
          "name": "storage.modifier.lifetime.rust",
          "match": "'[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.rust",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.rust",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*[({<])"
        }
      ]
    }
  }
}
