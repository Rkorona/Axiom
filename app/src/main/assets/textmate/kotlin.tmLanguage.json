{
  "name": "Kotlin",
  "scopeName": "source.kotlin",
  "fileTypes": ["kt", "kts"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.kotlin",
          "match": "//.*$"
        },
        {
          "name": "comment.block.kotlin",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.kotlin" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.kotlin" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.kotlin",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string-interpolation" }
          ]
        },
        {
          "name": "string.quoted.double.kotlin",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.kotlin", "match": "\\\\." },
            { "include": "#string-interpolation" }
          ]
        }
      ]
    },
    "string-interpolation": {
      "patterns": [
        {
          "name": "meta.template.expression.kotlin",
          "match": "(\\$\\{[^}]*\\}|\\$[a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "0": { "name": "variable.other.kotlin" }
          }
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.type.annotation.kotlin",
          "match": "@(?:file:|get:|set:|field:|param:|property:|receiver:|delegate:)?[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kotlin",
          "match": "\\b(if|else|when|for|while|do|return|break|continue|try|catch|finally|throw|in|!in|is|!is|as|as\\?)\\b"
        },
        {
          "name": "storage.type.kotlin",
          "match": "\\b(val|var|fun|class|object|interface|enum|sealed|data|typealias|package|import)\\b"
        },
        {
          "name": "storage.modifier.kotlin",
          "match": "\\b(public|private|protected|internal|open|abstract|final|override|companion|inline|noinline|crossinline|reified|suspend|operator|infix|tailrec|external|const|lateinit|expect|actual|vararg|out|in)\\b"
        },
        {
          "name": "keyword.operator.kotlin",
          "match": "\\b(by|where|get|set|init|constructor|this|super|dynamic)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.kotlin",
          "match": "\\b(true|false|null|it|this|super)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.kotlin",
          "match": "\\b(0x[0-9a-fA-F_]+[lL]?|0b[01_]+[lL]?|[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9]+)?[fFdDlL]?)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.kotlin",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.kotlin",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*[({<])"
        }
      ]
    }
  }
}
