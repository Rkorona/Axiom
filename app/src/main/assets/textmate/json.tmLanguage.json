{
  "name": "JSON",
  "scopeName": "source.json",
  "fileTypes": ["json", "jsonc"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#value" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.json", "match": "//.*$" },
        {
          "name": "comment.block.json",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "value": {
      "patterns": [
        { "include": "#object" },
        { "include": "#array" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#constant" }
      ]
    },
    "object": {
      "name": "meta.structure.dictionary.json",
      "begin": "\\{",
      "end": "\\}",
      "patterns": [
        {
          "name": "meta.structure.dictionary.key.json",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.json" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.json" } },
          "contentName": "support.type.property-name.json"
        },
        { "include": "#value" }
      ]
    },
    "array": {
      "name": "meta.structure.array.json",
      "begin": "\\[",
      "end": "\\]",
      "patterns": [{ "include": "#value" }]
    },
    "string": {
      "name": "string.quoted.double.json",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.json" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.json" } },
      "patterns": [{ "name": "constant.character.escape.json", "match": "\\\\." }]
    },
    "number": {
      "name": "constant.numeric.json",
      "match": "-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?"
    },
    "constant": {
      "name": "constant.language.json",
      "match": "\\b(true|false|null)\\b"
    }
  }
}
